{
  "name": "carbonwise",
  "version": "1.0.0",
  "description": "CarbonWise — AI-powered Carbon Footprint Awareness Platform that helps individuals understand, track, and reduce their carbon footprint through personalized insights.",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:unit": "node --experimental-vm-modules node_modules/.bin/jest tests/unit",
    "test:integration": "node --experimental-vm-modules node_modules/.bin/jest tests/integration",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "lint": "eslint server/ public/js/ tests/",
    "lint:fix": "eslint server/ public/js/ tests/ --fix",
    "typecheck": "tsc",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@google/generative-ai": "0.21.0",
    "@upstash/redis": "1.38.0",
    "compression": "1.8.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "csrf-csrf": "4.0.3",
    "csrf-sync": "4.2.1",
    "dotenv": "16.4.7",
    "express": "4.22.2",
    "express-rate-limit": "8.5.2",
    "express-validator": "7.3.2",
    "helmet": "8.0.0",
    "ioredis": "5.11.1",
    "rate-limit-redis": "5.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@jest/globals": "29.7.0",
    "@playwright/test": "1.60.0",
    "@types/express": "5.0.6",
    "@types/node": "25.9.2",
    "babel-jest": "^30.4.1",
    "eslint": "8.57.1",
    "jest": "29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "3.4.2",
    "supertest": "7.0.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "carbon-footprint",
    "sustainability",
    "ai-assistant",
    "gemini",
    "environment",
    "climate-change"
  ],
  "license": "MIT"
}
